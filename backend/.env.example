APP_NAME="CrimeLens Digital Forensic Intelligence"
ENVIRONMENT=dev
DEBUG=false
API_PREFIX=/api/v1

MONGO_URI=mongodb://mongodb:27017
MONGO_DB=crimelens

REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
DEEPINFRA_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
DEEPINFRA_TEMPERATURE=0.1

VECTOR_BACKEND=chromadb
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_DIMENSIONS=1024

MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=120

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123!
INVESTIGATOR_USERNAME=investigator
INVESTIGATOR_PASSWORD=investigator123!
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=analyst123!
