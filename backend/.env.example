APP_NAME="CrimeLens Digital Forensic Intelligence"
ENVIRONMENT=dev
DEBUG=false
API_PREFIX=/api/v1

MONGO_URI=mongodb://localhost:27017
MONGO_DB=crimelens

REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

JWT_SECRET_KEY=replace-with-a-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
DEEPINFRA_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
DEEPINFRA_TEMPERATURE=0.1

VECTOR_BACKEND=chromadb_cloud
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_COLLECTION_EVENTS=case_events
CHROMA_COLLECTION_CASES=case_summaries
EMBEDDING_DIMENSIONS=1024

MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=120
BEHAVIOR_CACHE_TTL_SECONDS=600

SUPER_ADMIN_EMAIL=superadmin@crimelens.local
SUPER_ADMIN_PASSWORD=change-super-admin-password
SUPER_ADMIN_FULL_NAME="Super Admin"
